{
  "name": "@base/design-system",
  "version": "0.0.1",
  "description": "Base Design System – open-source React component library for enterprise software tools",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
