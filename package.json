{
  "name": "@josephavelez77/charter-design-system",
  "version": "0.0.4",
  "description": "Charter Design System – open-source React component library for enterprise software tools",
  "license": "MIT",
  "homepage": "https://github.com/josephavelez77/charterdesignsystem#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/josephavelez77/charterdesignsystem"
  },
  "keywords": [
    "design-system",
    "react",
    "component-library",
    "typescript",
    "enterprise",
    "dark-mode",
    "css-tokens",
    "fontawesome"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./dist/index": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./dist/index.js": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens": {
      "types": "./dist/tokens/variables.d.ts",
      "default": "./dist/tokens/variables.css"
    },
    "./styles": {
      "types": "./dist/tokens/index.d.ts",
      "default": "./dist/tokens/index.css"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "llms.txt",
    "llms-full.txt"
  ],
  "sideEffects": [
    "dist/tokens/*.css"
  ],
  "scripts": {
    "build": "vite build && node -e \"const fs=require('fs'); fs.copyFileSync('src/tokens/index.css','dist/tokens/variables.css'); fs.writeFileSync('dist/tokens/index.d.ts',''); fs.writeFileSync('dist/tokens/variables.d.ts','');\"",
    "dev": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "tokens": "node scripts/generate-tokens.mjs",
    "llms": "node scripts/generate-llms.mjs"
  },
  "peerDependencies": {
    "@fortawesome/fontawesome-svg-core": ">=7",
    "@fortawesome/free-regular-svg-icons": ">=7",
    "@fortawesome/free-solid-svg-icons": ">=7",
    "@fortawesome/react-fontawesome": ">=0.2",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@mui/x-charts": "^9.5.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "node-fetch": "^3.3.2",
    "playwright": "^1.59.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^10.3.6",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.5"
  }
}
